# 노션 통합 시크릿 (https://www.notion.so/my-integrations 에서 발급)
NOTION_TOKEN=ntn_여기에_통합_시크릿_붙여넣기

# 보유종목 데이터베이스 ID (표 URL의 ?v= 앞 32자리)
NOTION_DATABASE_ID=여기에_보유종목_DATABASE_ID

# 자산기록(history) 데이터베이스 ID — 총자산 추이 누적용
NOTION_HISTORY_DATABASE_ID=여기에_자산기록_DATABASE_ID

# 가격기록(price) 데이터베이스 ID — 종목별 가격 추이 누적용 (선택, 없으면 생략됨)
NOTION_PRICE_DATABASE_ID=여기에_가격기록_DATABASE_ID
